{
  "name": "on-fire",
  "version": "1.0.0",
  "description": "Prevent sleep tray utility for Windows",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "npm run build:css && tsc && electron .",
    "start": "electron .",
    "build": "npm run build:css && tsc",
    "build:css": "npx tailwindcss -i ./src/renderer/input.css -o ./src/renderer/styles.css",
    "package": "npm run build && electron-builder",
    "convert-icons": "node scripts/convert-icons.js"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/node": "^20.0.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "png-to-ico": "^2.1.8",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "robotjs": "^0.6.0"
  }
}
